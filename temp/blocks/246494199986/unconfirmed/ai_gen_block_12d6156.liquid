{% doc %}
  @prompt
    Create custom CSS code that targets only sections using Color Scheme 1 and Color Scheme 2 to override heading colors. The CSS should set headings (h1, h2, h3, h4, h5, h6) to color #A15736 specifically for sections that have been assigned Color Scheme 1 or Color Scheme 2, without affecting other sections or color schemes.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if block.settings.custom_css != blank %}
  {% style %}
    {{ block.settings.custom_css }}
  {% endstyle %}
{% endif %}

<div class="ai-custom-css-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_css == blank %}
    <div class="ai-custom-css-empty-state-{{ ai_gen_id }}">
      <p>Add your custom CSS in the block settings to get started.</p>
    </div>
  {% else %}
    <div class="ai-custom-css-active-state-{{ ai_gen_id }}">
      <p>✅ Custom CSS is active</p>
    </div>
  {% endif %}
</div>

{% style %}
  .ai-custom-css-block-{{ ai_gen_id }} {
    padding: 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: 8px;
    text-align: center;
  }

  .ai-custom-css-empty-state-{{ ai_gen_id }} p {
    color: #666;
    font-style: italic;
    margin: 0;
  }

  .ai-custom-css-active-state-{{ ai_gen_id }} p {
    color: {{ block.settings.success_color }};
    font-weight: 500;
    margin: 0;
  }

  {% if block.settings.hide_indicator %}
    .ai-custom-css-block-{{ ai_gen_id }} {
      display: none;
    }
  {% endif %}
{% endstyle %}

{% schema %}
{
  "name": "Custom CSS",
  "settings": [
    {
      "type": "header",
      "content": "Custom CSS code"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "CSS code",
      "info": "Add your custom CSS here. Example: .color-scheme-1 h1, .color-scheme-2 h1 { color: #A15736; }"
    },
    {
      "type": "header",
      "content": "Block appearance"
    },
    {
      "type": "checkbox",
      "id": "hide_indicator",
      "label": "Hide status indicator",
      "default": false,
      "info": "Hide the visual indicator that shows whether CSS is active"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success indicator color",
      "default": "#008060"
    }
  ],
  "presets": [
    {
      "name": "Custom CSS"
    }
  ]
}
{% endschema %}