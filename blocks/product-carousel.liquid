{% comment %} blocks/product-carousel.liquid {% endcomment %}
{% assign block_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .product-carousel-{{ block_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .product-carousel__header-{{ block_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .product-carousel__heading-{{ block_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
  }

  .product-carousel__container-{{ block_id }} {
    position: relative;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .product-carousel__track-{{ block_id }} {
    display: flex;
    gap: {{ block.settings.product_spacing }}px;
    transition: transform 0.3s ease;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .product-carousel__track-{{ block_id }}::-webkit-scrollbar {
    display: none;
  }

  .product-carousel__product-{{ block_id }} {
    flex: 0 0 {{ block.settings.product_width }}px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .product-carousel__product-{{ block_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .product-carousel__image-wrapper-{{ block_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
  }

  .product-carousel__image-{{ block_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-carousel__product-{{ block_id }}:hover .product-carousel__image-{{ block_id }} {
    transform: scale(1.05);
  }

  .product-carousel__image-placeholder-{{ block_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-carousel__image-placeholder-{{ block_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .product-carousel__content-{{ block_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .product-carousel__title-{{ block_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 8px;
    font-weight: 500;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-carousel__price-{{ block_id }} {
    color: {{ block.settings.price_color }};
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .product-carousel__price-compare-{{ block_id }} {
    color: {{ block.settings.compare_price_color }};
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    text-decoration: line-through;
    margin-left: 8px;
    opacity: 0.7;
  }

  .product-carousel__nav-{{ block_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .product-carousel__nav-{{ block_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
    transform: translateY(-50%) scale(1.1);
  }

  .product-carousel__nav-{{ block_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: translateY(-50%) scale(1);
  }

  .product-carousel__nav--prev-{{ block_id }} {
    left: -20px;
  }

  .product-carousel__nav--next-{{ block_id }} {
    right: -20px;
  }

  .product-carousel__nav-{{ block_id }} svg {
    width: 20px;
    height: 20px;
  }

  .product-carousel__empty-state-{{ block_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .product-carousel__empty-state-{{ block_id }} h3 {
    margin: 0 0 10px;
    font-size: 18px;
  }

  .product-carousel__empty-state-{{ block_id }} p {
    margin: 0;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .product-carousel__product-{{ block_id }} {
      flex: 0 0 {{ block.settings.product_width | times: 0.8 }}px;
    }

    .product-carousel__nav-{{ block_id }} {
      display: none;
    }

    .product-carousel__container-{{ block_id }} {
      padding: 0 10px;
    }
  }
{% endstyle %}

<product-carousel-{{ block_id }}
  class="product-carousel-{{ block_id }}"
  data-products-per-view="{{ block.settings.products_per_view }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <div class="product-carousel__header-{{ block_id }}">
      <h2 class="product-carousel__heading-{{ block_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="product-carousel__container-{{ block_id }}">
    {% if block.settings.collection != blank and block.settings.collection.products.size > 0 %}
      <button
        class="product-carousel__nav-{{ block_id }} product-carousel__nav--prev-{{ block_id }}"
        aria-label="Previous products"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15,18 9,12 15,6"></polyline>
        </svg>
      </button>

      <div class="product-carousel__track-{{ block_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_limit %}
          <div class="product-carousel__product-{{ block_id }}">
            <a href="{{ product.url }}" class="product-carousel__link-{{ block_id }}">
              <div class="product-carousel__image-wrapper-{{ block_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="product-carousel__image-{{ block_id }}"
                    loading="lazy"
                    width="400"
                    height="{{ block.settings.image_height }}"
                  >
                {% else %}
                  <div class="product-carousel__image-placeholder-{{ block_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="product-carousel__content-{{ block_id }}">
                <h3 class="product-carousel__title-{{ block_id }}">{{ product.title }}</h3>
                <div class="product-carousel__price-{{ block_id }}">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="product-carousel__price-compare-{{ block_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <button
        class="product-carousel__nav-{{ block_id }} product-carousel__nav--next-{{ block_id }}"
        aria-label="Next products"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
    {% else %}
      <div class="product-carousel__empty-state-{{ block_id }}">
        <h3>No products to display</h3>
        <p>Select a collection with products to show in this carousel</p>
      </div>
    {% endif %}
  </div>
</product-carousel-{{ block_id }}>

<script>
  (function() {
    class ProductCarousel{{ block_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.prevButton = null;
        this.nextButton = null;
        this.currentIndex = 0;
        this.productsPerView = 4;
        this.totalProducts = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.product-carousel__track-{{ block_id }}');
        this.prevButton = this.querySelector('.product-carousel__nav--prev-{{ block_id }}');
        this.nextButton = this.querySelector('.product-carousel__nav--next-{{ block_id }}');
        
        if (!this.track) return;

        this.productsPerView = parseInt(this.dataset.productsPerView) || 4;
        this.totalProducts = this.track.children.length;

        this.setupEventListeners();
        this.updateNavigation();
        this.handleResize();

        window.addEventListener('resize', () => this.handleResize());
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevious());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.track.addEventListener('scroll', () => {
          this.updateCurrentIndex();
          this.updateNavigation();
        });
      }

      handleResize() {
        if (window.innerWidth <= 749) {
          this.productsPerView = 1.2;
        } else if (window.innerWidth <= 990) {
          this.productsPerView = Math.min(2, this.productsPerView);
        } else {
          this.productsPerView = parseInt(this.dataset.productsPerView) || 4;
        }
        this.updateNavigation();
      }

      goToPrevious() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.scrollToIndex(this.currentIndex);
        }
      }

      goToNext() {
        const maxIndex = Math.max(0, this.totalProducts - this.productsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.scrollToIndex(this.currentIndex);
        }
      }

      scrollToIndex(index) {
        const productWidth = this.track.children[0]?.offsetWidth || 0;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const scrollPosition = index * (productWidth + gap);
        
        this.track.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });
      }

      updateCurrentIndex() {
        const productWidth = this.track.children[0]?.offsetWidth || 0;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        this.currentIndex = Math.round(this.track.scrollLeft / (productWidth + gap));
      }

      updateNavigation() {
        if (!this.prevButton || !this.nextButton) return;

        const maxIndex = Math.max(0, this.totalProducts - Math.floor(this.productsPerView));
        
        this.prevButton.disabled = this.currentIndex <= 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }
    }

    customElements.define('product-carousel-{{ block_id }}', ProductCarousel{{ block_id }});
  })();
</script>

{% schema %}
{
