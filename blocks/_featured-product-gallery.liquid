

{% render 'card-gallery' %}

{% schema %}
{
  "name": "Product media",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays media from parent product"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Auto"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "adapt",
      "label": "Aspect ratio"
    },
    {
      "type": "select",
      "id": "constrain_to_viewport",
      "options": [
        {
          "value": "",
          "label": "Off"
        },
        {
          "value": "contain",
          "label": "Maintain aspect ratio"
        },
        {
          "value": "cover",
          "label": "Crop to fit"
        }
      ],
      "default": "contain",
      "label": "Constrain to screen height",
      "visible_if": "{{ block.settings.image_ratio == 'adapt' }}"
    }
  ]
}
{% endschema %}
