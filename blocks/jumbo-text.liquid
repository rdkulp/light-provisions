

{% render 'jumbo-text' %}

{% schema %}
{
  "name": "Jumbo text",
  "tag": null,
  "settings": [
    {
      "id": "text",
      "type": "textarea",
      "label": "Text",
      "default": "Be bold."
    },
    {
      "type": "select",
      "id": "font",
      "label": "Font",
      "options": [
        {
          "value": "body",
          "label": "Body"
        },
        {
          "value": "subheading",
          "label": "Subheading"
        },
        {
          "value": "heading",
          "label": "Heading"
        },
        {
          "value": "accent",
          "label": "Accent"
        }
      ],
      "default": "heading"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Alignment",
      "default": "left"
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "0.8",
          "label": "Tight"
        },
        {
          "value": "1",
          "label": "Normal"
        },
        {
          "value": "1.2",
          "label": "Loose"
        }
      ],
      "default": "0.8"
    },
    {
      "type": "select",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "options": [
        {
          "value": "-0.03em",
          "label": "Tight"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "0.03em",
          "label": "Loose"
        }
      ],
      "default": "-0.03em"
    },
    {
      "type": "select",
      "id": "case",
      "label": "Case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "text_effect",
      "label": "Effects",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "blur",
          "label": "Blur"
        },
        {
          "value": "reveal",
          "label": "Reveal"
        }
      ],
      "default": "none"
    },
    {
      "type": "checkbox",
      "id": "animation_repeat",
      "label": "Repeat animation",
      "default": false,
      "visible_if": "{{ block.settings.text_effect == \"blur\" or block.settings.text_effect == \"reveal\" }}"
    }
  ],
  "presets": [
    {
      "name": "Jumbo text",
      "category": "Decorative"
    }
  ]
}
{% endschema %}
