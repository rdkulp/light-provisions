{% comment %} sections/featured_articles.liquid 10/25 rk {% endcomment %}

{% liquid
  assign blog = section.settings.blog
  assign articles = blog.articles
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
    --resource-list-column-gap-desktop: {{ section.settings.columns_gap }}px;
    --resource-list-row-gap-desktop: {{ section.settings.rows_gap }}px;
    --resource-list-columns: repeat({{ section.settings.columns }}, 1fr);
    --resource-list-columns-mobile: repeat({{ section.settings.mobile_columns }}, 1fr);
    --column-count-mobile: {{ section.settings.mobile_columns }};
  "
>
  <div class="section-resource-list__content">
    {% if section.settings.heading != blank %}
      <div class="section-resource-list__header">
        <h2 class="h2">{{ section.settings.heading }}</h2>
      </div>
    {% endif %}
  </div>

  <div class="resource-list resource-list--grid">
    {% for article in articles limit: section.settings.limit %}
      <div class="resource-list__item">
        {% render 'article-card', article: article %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
  {
    "name": "Featured Articles",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured Articles"
      },
      {
        "type": "blog",
        "id": "blog",
        "label": "Blog"
      },
      {
        "type": "select",
        "id": "limit",
        "label": "Number of articles to show",
        "default": "3",
        "options": [
          {
            "value": "3",
            "label": "3"
          },
          {
            "value": "4",
            "label": "4"
          },
          {
            "value": "5",
            "label": "5"
          },
          {
            "value": "6",
            "label": "6"
          }
        ]
      },
      {
        "type": "header",
        "content": "Layout"
      },
      {
        "type": "select",
        "id": "section_width",
        "label": "Section width",
        "default": "page-width",
        "options": [
          {
            "value": "page-width",
            "label": "Page width"
          },
          {
            "value": "full-width",
            "label": "Full width"
          }
        ]
      },
      {
        "type": "range",
        "id": "columns",
        "label": "Number of columns on desktop",
        "min": 1,
        "max": 6,
        "step": 1,
        "default": 3
      },
      {
        "type": "range",
        "id": "mobile_columns",
        "label": "Number of columns on mobile",
        "min": 1,
        "max": 3,
        "step": 1,
        "default": 1
      },
      {
        "type": "range",
        "id": "columns_gap",
        "label": "Gap between columns",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "px",
        "default": 20
      },
      {
        "type": "range",
        "id": "rows_gap",
        "label": "Gap between rows",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "px",
        "default": 20
      },
      {
        "type": "range",
        "id": "gap",
        "label": "Gap between content",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "px",
        "default": 20
      },
      {
        "type": "header",
        "content": "Spacing"
      },
      {
        "type": "range",
        "id": "padding-block-start",
        "label": "Top padding",
        "min": 0,
        "max": 200,
        "step": 5,
        "unit": "px",
        "default": 40
      },
      {
        "type": "range",
        "id": "padding-block-end",
        "label": "Bottom padding",
        "min": 0,
        "max": 200,
        "step": 5,
        "unit": "px",
        "default": 40
      },
      {
        "type": "range",
        "id": "padding-inline-start",
        "label": "Left padding",
        "min": 0,
        "max": 200,
        "step": 5,
        "unit": "px",
        "default": 0
      },
      {
        "type": "range",
        "id": "padding-inline-end",
        "label": "Right padding",
        "min": 0,
        "max": 200,
        "step": 5,
        "unit": "px",
        "default": 0
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "select",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "background-1",
        "options": [
          {
            "value": "background-1",
            "label": "Background 1"
          },
          {
            "value": "background-2",
            "label": "Background 2"
          },
          {
            "value": "background-3",
            "label": "Background 3"
          },
          {
            "value": "background-4",
            "label": "Background 4"
          },
          {
            "value": "background-5",
            "label": "Background 5"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Featured Articles"
      }
    ]
  }
{% endschema %}