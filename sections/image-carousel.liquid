{% liquid
  assign slide_count = section.blocks.size
  assign show_arrows = false
  assign show_controls = false
  assign arrow_style = section.settings.arrow_style | default: 'arrow'
  
  if slide_count > 1
    unless arrow_style == 'none'
      assign show_arrows = true
    endunless
    assign show_controls = true
  endif
%}

{% capture slides %}
  {% for block in section.blocks %}
    {% capture slide_content %}
      <div class="image-carousel__slide">
        <img 
          src="{{ block.settings.image | image_url: width: 800 }}" 
          alt="{{ block.settings.image.alt | escape }}"
          width="800"
          height="600"
          loading="lazy"
        >
      </div>
    {% endcapture %}
    {% render 'slideshow-slide', 
      children: slide_content, 
      index: forloop.index0,
      slide_id: block.id
    %}
  {% endfor %}
{% endcapture %}

{% if show_controls %}
  {% capture controls %}
    <slideshow-controls ref="slideshowControls">
      <slideshow-dots ref="dots[]">
        {% for block in section.blocks %}
          <button type="button" aria-label="Go to slide {{ forloop.index }}">
            <span></span>
          </button>
        {% endfor %}
      </slideshow-dots>
    </slideshow-controls>
  {% endcapture %}
{% endif %}

<section class="section image-carousel-section">
  {% render 'slideshow',
    slides: slides,
    slide_count: slide_count,
    show_arrows: show_arrows,
    icon_style: arrow_style,
    controls: controls,
    class: 'image-carousel__slideshow',
    infinite: true,
    autoplay: section.settings.autoplay,
    autoplay_speed: section.settings.autoplay_speed
  %}
</section>

{% stylesheet %}
  .image-carousel-section {
    --slideshow-slide-aspect-ratio: auto;
  }

  .image-carousel__slideshow {
    width: 100%;
    height: 537px;
  }

  .image-carousel__slideshow slideshow-slides {
    gap: 16px;
    height: 537px;
    scroll-snap-type: x mandatory;
    overflow-x: auto;
    overflow-y: hidden;
  }

  .image-carousel__slideshow slideshow-slide {
    flex: 0 0 calc((100% - 48px) / 3.5) !important; /* Override slideshow default width */
    width: calc((100% - 48px) / 3.5) !important;
    min-width: calc((100% - 48px) / 3.5) !important;
    max-width: calc((100% - 48px) / 3.5) !important;
    height: 537px;
    scroll-snap-align: start;
  }

  .image-carousel__slide {
    width: 100%;
    height: 537px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-carousel__slide img {
    width: 100%;
    height: 537px;
    object-fit: cover;
    border-radius: var(--border-radius);
  }

  /* Responsive adjustments */
  @media (max-width: 1200px) {
    .image-carousel__slideshow slideshow-slide {
      flex: 0 0 calc((100% - 32px) / 2.5) !important;
      width: calc((100% - 32px) / 2.5) !important;
      min-width: calc((100% - 32px) / 2.5) !important;
      max-width: calc((100% - 32px) / 2.5) !important;
    }
  }

  @media (max-width: 768px) {
    .image-carousel__slideshow,
    .image-carousel__slideshow slideshow-slides,
    .image-carousel__slide img {
      height: 400px;
    }
    
    .image-carousel__slideshow slideshow-slide {
      flex: 0 0 calc((100% - 16px) / 1.5) !important;
      width: calc((100% - 16px) / 1.5) !important;
      min-width: calc((100% - 16px) / 1.5) !important;
      max-width: calc((100% - 16px) / 1.5) !important;
      height: 400px;
    }
  }

  /* Arrow positioning for image carousel */
  .image-carousel__slideshow slideshow-arrows {
    --arrow-size: 48px;
    --arrow-background: rgba(255, 255, 255, 0.9);
    --arrow-color: var(--color-foreground);
  }

  .image-carousel__slideshow slideshow-arrows button {
    backdrop-filter: blur(4px);
  }

  /* Dots styling */
  .image-carousel__slideshow slideshow-controls {
    margin-top: 1rem;
  }

  .image-carousel__slideshow slideshow-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .image-carousel__slideshow slideshow-dots button {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    background: rgba(var(--color-foreground-rgb), 0.3);
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .image-carousel__slideshow slideshow-dots button[aria-selected="true"] {
    background: rgb(var(--color-foreground-rgb));
  }

  .image-carousel__slideshow slideshow-dots button span {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Image Carousel",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Slide rotation speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "select",
      "id": "arrow_style",
      "label": "Arrow style",
      "options": [
        {
          "value": "arrow",
          "label": "Arrows"
        },
        {
          "value": "chevron",
          "label": "Chevrons"
        },
        {
          "value": "arrows_large",
          "label": "Large arrows"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "arrow"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}